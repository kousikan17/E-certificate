# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=twinverify
DB_USER=postgres
DB_PASS=postgres
# Optional cloud connection string (takes precedence over DB_HOST/DB_NAME/...)
DATABASE_URL=
# Set true for managed Postgres providers that require SSL
DB_SSL=false

# JWT Secret
JWT_SECRET=your_jwt_secret_here_change_this

# Server
PORT=5000
FRONTEND_URL=http://localhost:3000

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
